  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate 3-phase PWM motor control to new AURIX target",
      "functional_behavior": "Provide center-aligned complementary PWM for three phases (U, V, W) at 20 kHz with 1 µs deadtime (rising and falling), synchronous start and synchronous duty updates, push-pull/pad driver settings as requested, GTM enable guard, a period-callback stub, an ATOM ISR toggling LED P13.0, and main stepping duty every 500 ms with wrap.",
      "technical_approach": "Use the unified high-level PWM driver to configure a 3-phase complementary topology on TOM1/Cluster_1. Route the six TOUTs via the driver's pin configuration (mapping confirmed from IfxGtm_PinMap.h at integration time), set push-pull and the requested pad driver in config, enable GTM via a guard check, register a period event callback stub, and provide two preserved functions: initGtmTom3phInv() for one-shot setup (including initial 25/50/75% duties, center alignment, complementary outputs, deadtime, sync start/updates), and updateGtmTom3phInvDuty() for percent-based synchronous multi-channel duty updates respecting the 10% step and wrap rules. A separate GTM ATOM channel ISR (prio 20) toggles P13.0 and is wired through the project’s interrupt configuration."
    },
    "driver_selection": {
      "recommended_driver": "IfxGtm_Pwm",
      "selection_rationale": "Unified high-level PWM was explicitly requested and is mandated for migration. It natively supports multi-channel center-aligned complementary generation with synchronous start/updates and deadtime management, minimizing low-level TOM/DTM handling while preserving the reference function names and intended behavior.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxGtm_Tom_Dtm_PwmHl",
