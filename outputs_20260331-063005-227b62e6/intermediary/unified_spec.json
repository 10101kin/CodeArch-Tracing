  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate the existing 3-phase inverter PWM from GTM TOM (TC3xx) to eGTM ATOM (TC4xx) on KIT_A3G_TC4D7_LITE.",
      "functional_behavior": "Produce six complementary, center-aligned PWM outputs at 20 kHz with 1 µs rising/falling dead-time on eGTM ATOM0 Cluster 0; initial duties U/V/W = 25/50/75%, 10% duty step, synchronous start and updates enabled, HS active-high and LS active-low, push-pull drive; generate a period-event ISR on CPU0 that toggles LED P03.9.",
      "technical_approach": "Use the unified high-level PWM driver to configure ATOM0 Cluster 0 with complementary pairs and DTM, apply center-aligned timing and dead-time via the driver config, route TOUT pins through the unified config, enable CMU clocks, and attach a period event interrupt that toggles the LED. Duties are updated at runtime with the unified multi-channel duty update API."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "It is the unified high-level PWM driver for TC4xx eGTM that directly supports ATOM-based complementary PWM with DTM, center alignment, synchronous start/update, and period interrupts, matching the migration goal and required features.",
