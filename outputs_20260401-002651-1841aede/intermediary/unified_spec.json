  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate 3-phase PWM motor control to new AURIX target",
      "functional_behavior": "Produce six center-aligned complementary PWM outputs at 20 kHz with 1 µs rising/falling dead-time, initial duties U=25%, V=50%, W=75%, 10% duty step updates, HS active-high/LS active-low, push-pull with cmosAutomotiveSpeed1, synchronized start and updates, and a PWM-period ISR on CPU0 that toggles LED P03.9.",
      "technical_approach": "Use the unified EGTM PWM driver on ATOM0 Cluster 0 to configure one base plus five synced channels (three HS/LS pairs) with DTM-based complementary outputs and requested polarities, pad driver, and sync behaviors. Enable EGTM clocks (FXCLK0 and DTM0) via CMU, then initialize with IfxEgtm_Pwm_initConfig/IfxEgtm_Pwm_init. Duty updates are done atomically via IfxEgtm_Pwm_updateChannelsDutyImmediate; LED toggling occurs in the PWM period ISR using IfxPort APIs. Pin routing, DTM/dead-time, polarity, and ISR setup are handled in the unified driver configuration."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified PWM driver natively supports EGTM ATOM with center-aligned complementary pairs, DTM dead-time, synchronized start/update, and consolidated pin/polarity/ISR handling—ideal for migrating TOM→ATOM while minimizing code changes.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm",
        "IfxGtm_Pwm"
      ]
    },
