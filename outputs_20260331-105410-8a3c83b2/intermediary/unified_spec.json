  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Implement 3-phase PWM motor control",
      "functional_behavior": "Drive a 3-phase inverter with complementary, center-aligned PWM on ATOM CH0–2 with hardware dead-time and provide an edge-aligned 50% trigger on ATOM CH3 routed to TMADC; acquire TMADC multiple channels on trigger and toggle a status LED in the ADC ISR; ramp motor phase duties periodically from main.",
      "technical_approach": "Use the unified high-level PWM driver to configure EGTM Cluster 0 ATOM channels for a synchronous 3-phase inverter with complementary outputs and dead-time; initialize EGTM clocks and pins, then initialize PWM with the unified config and start synchronized channels. Route ATOM CH3 trigger to TMADC via IfxEgtm_Trigger_trigToAdc using the specified AdcTriggerSignal. Initialize TMADC module and channels, enable events, and run the module; in resultISR() read the TMADC result using available TMADC result APIs and toggle the LED using IfxPort. In Cpu0_Main.c, disable watchdogs, call the preserved init functions, and periodically call updateEgtmAtom3phInvDuty() to ramp U/V/W duties."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified PWM driver is locked by requirements and best matches a synchronized multi-channel ATOM-based 3-phase complementary, center-alignedPWM with dead-time and array-based duty updates while abstracting low-level ATOM/DTM details.",
      "available_in_template": true,
      "complexity_level": "advanced",
