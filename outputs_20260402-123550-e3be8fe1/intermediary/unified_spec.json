  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate an existing 3-phase inverter PWM + synchronous ADC sampling application to a TC4D7 target using EGTM ATOM and TMADC with unified high-level drivers.",
      "functional_behavior": "Generate three center-aligned complementary PWM phases with fixed dead time, provide a synchronized ADC trigger, run TMADC conversions with an interrupt that reads results and toggles a debug pin, and periodically update duties at runtime using the immediate multi-channel duty update API.",
      "technical_approach": "Use the unified IfxEgtm_Pwm driver to configure EGTM ATOM PWM channels and dead-time, enable EGTM clocks, and initialize via initConfig/init. Configure the TMADC module and channels for one-shot conversions and route the EGTM trigger using IfxEgtm_Trigger_trigToAdc. Install the ADC channel event, run TMADC, and implement the ISR to read results and toggle the debug GPIO. In main, disable watchdogs, call initEgtmAtom3phInv once, then periodically call the preserved update function that uses IfxEgtm_Pwm_updateChannelsDutyImmediate."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified PWM driver matches the migration target, supports ATOM center-aligned complementary outputs, synchronous multi-channel updates, dead-time, and integrates cleanly with EGTM trigger routing for ADC synchronization while minimizing low-level handling.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm",
        "IfxGtm_Pwm"
      ]
    },
