  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate the existing TC387 3‑phase inverter PWM from IfxGtm_Tom_PwmHl to the unified IfxGtm_Pwm while keeping the same behavior and timing.",
      "functional_behavior": "Generate center-aligned 20 kHz PWM on TOM1, Cluster_1 with CH0 as master and complementary HS/LS pairs per phase: (1,2)=U, (3,4)=V, (5,6)=W; active-high, push-pull, 1 µs rising/falling dead time, 1 µs min pulse, synchronized start and synchronized duty updates, pad driver set to automotive speed 1. Initialize to U=25%, V=50%, W=75% and update every 500 ms using the specified wrap rule. Provide a stub IfxGtm_periodEventFunction(). Also generate a 10 Hz GTM ATOM0 CH0 interrupt (priority 20, on CPU0) that toggles P13.0.",
      "technical_approach": "Use the unified high-level IfxGtm_Pwm to configure TOM1 Cluster_1 with CH0 master and three complementary HS/LS channel pairs, setting center alignment, sync start/update, dead time, min pulse, polarity, push-pull, clock source cmuFxclk0, and the verified TOUT pin mappings from IfxGtm_PinMap for TC38x LFBGA516. Guard GTM enablement via IfxGtm_isEnabled/IfxGtm_enable and enable FXCLK0 via IfxGtm_Cmu_enableClocks only if needed. Preserve reference function names by providing initGtmTom3phInv() to initialize PWM and pins safely, updateGtmTom3phInvDuty() to apply percent duties (0–100) using synchronized updates, and a stub IfxGtm_periodEventFunction(). Configure a 10 Hz ATOM0 timer interrupt with IfxGtm_Atom_Timer and toggle P13.0 in its ISR. Main calls init once and periodically updates duties every 500 ms using IfxStm_getTicksFromMilliseconds."
    },
    "driver_selection": {
      "recommended_driver": "IfxGtm_Pwm",
      "selection_rationale": "Unified high-level GTM PWM driver meets the migration target, supports center-aligned, complementary outputs with dead time and synchronized start/update for multiple channels, and simplifies initialization while matching the user’s TOM1/Cluster_1 requirements.",
      "available_in_template": true,
      "complexity_level": "moderate",
      "alternatives_considered": [
        "IfxGtm_Tom_PwmHl",
        "IfxGtm_Tom_Dtm_PwmHl",
        "IfxGtm_Tom_Pwm"
      ]
    },
    "driver_usage": {
