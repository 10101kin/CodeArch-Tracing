  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate the TC387 3-phase inverter PWM to the unified GTM PWM driver while keeping behavior and interfaces intact.",
      "functional_behavior": "Generate 3-phase, center-aligned 20 kHz PWM on TOM1 with CH0 as master and complementary HS/LS pairs (1,2)=U, (3,4)=V, (5,6)=W; synchronized start and synchronized duty updates; enforce 1 us dead time and 1 us minimum pulse, active-high push-pull outputs with specified pad driver; expose initGtmTom3phInv() and updateGtmTom3phInvDuty() using percent input and the wrap rule; provide a stub IfxGtm_periodEventFunction(); add a 10 Hz ATOM0 CH0 ISR toggling P13.0; main updates duty every 500 ms using STM ticks.",
      "technical_approach": "Use the unified high-level GTM PWM driver to configure TOM1 Cluster_1 with CH0 as the master and three complementary channel pairs, enabling synchronized start/update and center alignment in the config. Map the verified TOM1→TOUT pins via the driver’s pin configuration, set active-high push-pull and the requested pad driver, and configure dead time and minimum pulse constraints in the PWM config. Guard GTM/CMU enablement using IfxGtm_isEnabled/IfxGtm_enable and enable the required FXCLK only when needed. Provide initGtmTom3phInv() to build and apply the PWM configuration and start outputs in a safe state, and updateGtmTom3phInvDuty() to apply percent-based duty commands simultaneously via the unified group update API while enforcing the wrap rule. Implement a lightweight stub IfxGtm_periodEventFunction() for future period-event hooks. Configure a separate 10 Hz timer on ATOM0 CH0 and install an ISR (priority 20, provider cpu0) that toggles P13.0 on each interrupt; use STM ticks in main to call the duty update every 500 ms."
    },
    "driver_selection": {
      "recommended_driver": "IfxGtm_Pwm",
      "selection_rationale": "It is the unified high-level PWM driver that natively supports multi-channel synchronized start/update, center alignment, complementary pairs with dead time and minimum pulse management, and integrates TOM pin routing in its configuration. It directly replaces the legacy PwmHl with simpler initialization and a single group duty update call, preserving the required behavior and simplifying migration.",
      "available_in_template": true,
      "complexity_level": "moderate",
      "alternatives_considered": [
        "IfxGtm_Tom_PwmHl",
        "IfxGtm_Tom_Dtm_PwmHl",
        "IfxGtm_Tom_Pwm"
      ]
    },
    "driver_usage": {
