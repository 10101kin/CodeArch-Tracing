  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Implement 3-phase PWM motor control",
      "functional_behavior": "Generate 3-phase, center-aligned 20 kHz PWM on TOM1.CL1 with complementary HS/LS per phase and 1 µs rising/falling dead time, synchronous start and synchronous duty updates; guard GTM enable (skip re-enable if already on); provide initGtmTom3phInv(void), updateGtmTom3phInvDuty(void), an empty IfxGtm_periodEventFunction, and a 10 Hz GTM ATOM0 CH0 ISR toggling P13.0; main loop updates every 500 ms using the STM timebase with step-and-wrap duty logic.",
      "technical_approach": "Use the unified PWM driver to configure TOM1.CL1 as a 3-phase complementary inverter with hardware dead time and center-aligned mode. Sync start/update are enabled via the Pwm configuration, and buffered duty updates (updateChannelsDuty) ensure synchronous application. Before PWM setup, check GTM enable state and enable only if disabled. LED P13.0 is configured with IfxPort and toggled in the 10 Hz ATOM ISR. The empty IfxGtm_periodEventFunction stub is provided. Final TOM1.CH[8..13] to P02.x mapping is validated against the TC38x LFBGA-516 pin map while keeping the unified driver’s pin handling in its config."
    },
    "driver_selection": {
      "recommended_driver": "IfxGtm_Pwm",
      "selection_rationale": "It is the unified high-level PWM driver locked by requirements; it natively supports TOM center-aligned operation, complementary outputs with hardware dead time, and synchronous start/update using a single cohesive configuration, minimizing code and matching the migration goal.",
