    "peripheral_requirement": {
      "type": "PWM",
      "driver_available": true,
      "driver_name": "IfxGtm_Pwm",
      "purpose": "3-phase inverter PWM using GTM TOM1 Cluster_1 in center-aligned mode at 20 kHz with complementary HS/LS per phase and 1 µs hardware dead-time; synchronous start and update enabled; duty update step logic in main loop. Includes GTM ATOM0 CH0 ISR at 10 Hz to toggle LED on P13.0.",
      "gtm_enable_guard": "Before GTM use, check MODULE_GTM.CLC.B.DISS; if DISS==1 then unlock and clear DISR, wait until DISS==0; if DISS==0, do not re-enable.",
      "driver_locked": true,
      "driver_selection_source": "engine_scored"
    },
    "signal_requirements": {
      "pwm_phases": [
        {
          "phase": "U",
          "hs_pin": "P02.0",
          "ls_pin": "P02.7",
          "module": "TOM1",
          "cluster": 1,
          "assumed_channels": {
            "hs": 8,
            "ls": 9
          },
          "assignment_note": "Assume Cluster_1 maps to TOM1 CH[8..15]. Verify exact P02.0/P02.7 pin-to-channel mapping with IfxGtm_PinMap.h for TC38x LFBGA516; adjust channels if pin map differs."
        },
        {
          "phase": "V",
          "hs_pin": "P02.1",
          "ls_pin": "P02.4",
          "module": "TOM1",
          "cluster": 1,
          "assumed_channels": {
            "hs": 10,
            "ls": 11
          },
          "assignment_note": "Verify via IfxGtm_PinMap.h for TC38x LFBGA516."
        },
        {
          "phase": "W",
          "hs_pin": "P02.2",
          "ls_pin": "P02.5",
          "module": "TOM1",
          "cluster": 1,
          "assumed_channels": {
            "hs": 12,
            "ls": 13
          },
          "assignment_note": "Verify via IfxGtm_PinMap.h for TC38x LFBGA516."
        }
      ],
      "led": {
        "pin": "P13.0",
        "direction": "outputPushPull",
        "default_state": "low"
      },
      "interrupts": [
        {
          "source": "GTM_ATOM0_CH0",
          "priority": 20,
          "cpu": "cpu0",
          "purpose": "10 Hz LED toggle on P13.0"
        }
      ]
    },
    "timing_requirements": {
      "pwm": {
        "frequency_hz": 20000,
        "alignment": "center",
        "complementary_outputs": true,
        "dead_time_s": {
          "rising": 1e-06,
          "falling": 1e-06
        },
        "synchronous_start": true,
        "synchronous_update": true,
        "min_pulse_time_s": 1e-06,
        "initial_duty_percent": {
          "U": 25,
          "V": 50,
          "W": 75
        },
        "duty_update_step_percent": 10,
        "duty_wrap_rule": "If (duty + step) >= 100, set duty to 0 then add step (resulting duty = step).",
        "duty_limits_percent": {
          "min": 0,
          "max": 100
        }
      },
      "atom_isr": {
        "module": "ATOM0",
        "channel": 0,
        "frequency_hz": 10,
        "action": "Toggle P13.0"
      },
      "main_loop_update": {
        "period_ms": 500,
        "timebase": "IfxStm_getTicksFromMilliseconds(BSP_DEFAULT_TIMER, 500)"
      }
