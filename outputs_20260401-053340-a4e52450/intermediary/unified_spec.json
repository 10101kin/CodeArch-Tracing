  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate 3-phase PWM motor control to new AURIX target",
      "functional_behavior": "Generate three complementary, center-aligned PWM pairs at 20 kHz with 1 µs rising/falling dead-time and initial duties U/V/W = 25/50/75 on EGTM Cluster 0 ATOM0 CH0–CH2; configure ATOM0 CH3 as a 50% edge-aligned ADC trigger routed to TMADC0 on falling edge; acquire TMADC0 CH0–CH4 one-shot via SAR0 with 100 ns sampling and wait-for-read; handle results in resultISR() (priority 25, CPU0, vmId IfxSrc_VmId_0); heartbeat on P03.9 and duty step every 500 ms.",
      "technical_approach": "Use the unified EGTM PWM driver to set up ATOM0 CH0–CH2 as center-aligned complementary pairs with DTM dead-time and CH3 as a 50% edge-aligned trigger channel on the specified TOUT; enable EGTM clocks, initialize PWM with requested frequency and duties, and route ATOM0 CH3 to TMADC via IfxEgtm_Trigger_trigToAdc using the specified trigger signal/mux and falling edge; initialize TMADC0 with module/channels (one-shot, SAR0, 100 ns) and run; install resultISR() to read the 5 channel results; toggle heartbeat and update duties in the main loop."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified EGTM PWM provides center/edge alignment, complementary outputs with hardware dead-time via DTM, synchronous multi-channel updates, and group start behavior needed for a 3-phase inverter; it directly supports ATOM submodule on TC4xx and aligns with the migration mappings.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm",
        "IfxGtm_Pwm"
      ]
    },
    "driver_usage": {
      "initialization_apis": [
        "IfxEgtm_Cmu_enableClocks",
        "IfxEgtm_Pwm_initConfig",
        "IfxEgtm_Pwm_init",
        "IfxEgtm_isEnabled",
