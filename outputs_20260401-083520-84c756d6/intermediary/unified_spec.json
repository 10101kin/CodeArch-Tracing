  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate PWM functionality to new AURIX target",
      "functional_behavior": "Generate three complementary, center‑aligned PWM phase pairs with 1 µs dead-time on ATOM0 CH0–CH2, plus an edge‑aligned 50% duty trigger on ATOM0 CH3 routed to TMADC0; configure TMADC0 CH0–CH4 one‑shot with 100 ns sampling and falling-edge trigger; read results in resultISR and toggle LED; update U/V/W duties every 500 ms.",
      "technical_approach": "Use the unified EGTM high-level PWM driver to configure ATOM0 channels (center-aligned + complementary with hardware DTM dead-time) and an additional edge-aligned channel for ADC triggering; route the trigger via the EGTM Trigger API to TMADC. Initialize and run TMADC0 with the high-level TMADC driver, enable channel event to raise the ISR, and access results in resultISR. Replace SCU WDT calls with WTU init APIs. Periodically update PWM duties immediately at runtime."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified high-level EGTM PWM fits ATOM-based, center-aligned, complementary outputs with hardware dead-time and supports immediate duty updates and trigger generation, aligning with the migration goal while avoiding low-level submodule calls.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxGtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm"
      ]
    },
