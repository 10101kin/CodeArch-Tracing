  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Implement 3-phase PWM motor control with synchronized ADC sampling on TC4D7.",
      "functional_behavior": "Generate complementary, center-aligned 3-phase PWM on EGTM ATOM with hardware dead-time; produce a 50% edge-aligned trigger for TMADC; run TMADC channels in one-shot with an interrupt that reads results and toggles a debug pin; periodically update duty cycles from main.",
      "technical_approach": "Use the unified EGTM Pwm driver to configure ATOM channels for a 3-phase complementary inverter with dead-time and a separate ATOM channel for the ADC trigger; route the trigger to TMADC via EGTM Trigger; initialize TMADC in one-shot mode and install the result ISR; in main, disable watchdogs, then periodically update all three PWM duties using the unified driver’s immediate update API."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified high-level PWM provides center/edge alignment, complementary outputs, dead-time handling, synchronous updates, and integrates pin/ISR setup via config. It matches the ATOM-based 3-phase inverter plus runtime duty updates while keeping code simple and portable for TC4xx.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm"
      ]
    },
