  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate 3-phase PWM motor control from TC387 GTM TOM to TC4D7 using eGTM ATOM0 unified API.",
      "functional_behavior": "Generate 6 complementary, center-aligned PWM outputs at 20 kHz with 1 µs rising and falling dead-time; HS active-high, LS active-low; initial duties U=25%, V=50%, W=75%; duty step=10%; use FXCLK0 as time base with syncStart/syncUpdate; toggle LED on each PWM period ISR with priority=20 on CPU0 and vmId=IfxSrc_VmId_0.",
      "technical_approach": "Use the unified PWM driver on eGTM ATOM0 (Cluster 0) to configure one base and five synchronous channels as complementary pairs with center alignment and hardware dead-time via DTM integration in the unified config. Enable CMU FXCLK0 as the time base, keep synchronous start/update enabled, and attach a period ISR for LED toggling. Preserve reference function names for init and runtime duty updates."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified PWM driver directly supports center-aligned complementary PWM with dead-time, synchronous start/update, frequency/duty updates, and period ISR integration on eGTM ATOM, matching the migration target and minimizing low-level handling.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
