{
  "user_intent_preservation": {
    "original_goal": "Migrate the TC387 TOM-based 3-phase inverter PWM to TC4D7 eGTM ATOM on KIT_A3G_TC4D7_LITE using the unified PWM driver, keeping 20 kHz center-aligned complementary PWM with 1 µs dead-time, HS active-high and LS active-low, push-pull outputs, AGC synchronized start, CMU FXCLK0 for ATOM and CMU CLK0 for DTM, and a period ISR on CPU0 priority 20.",
    "functional_behavior": "Generate 3-phase center-aligned complementary PWM at 20 kHz with 1 µs hardware dead-time using ATOM+CDTM, start all channels synchronously via AGC, route outputs to P20.8..P20.13 in push-pull with HS active-high and LS active-low, run a period interrupt on CPU0 with priority 20.",
    "technical_approach": "Use unified high-level IfxEgtm_Pwm to configure ATOM0 channels (0..5) as base+sync channels with center-aligned mode and complementary outputs via CDTM with 1 µs dead-time. Enable FXCLK0 for ATOM and CLK0 for DTM via IfxEgtm_Cmu and IfxEgtm_Dtm. Map the six outputs to P20.8..P20.13 using IfxEgtm_PinMap_setAtomTout. Start channels synchronously using IfxEgtm_Pwm_startSyncedChannels. Install a period ISR on CPU0 (prio 20) and call IfxEgtm_Pwm_interruptHandler from the ISR."
  },
