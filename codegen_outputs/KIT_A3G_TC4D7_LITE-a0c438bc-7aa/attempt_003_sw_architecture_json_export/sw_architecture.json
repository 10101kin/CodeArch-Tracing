{
  "user_intent_preservation": {
    "original_goal": "Migrate 3-phase PWM motor control from TC387 (GTM TOM + EVADC) to TC4D7 (eGTM ATOM + TMADC) on KIT_A3G_TC4D7_LITE.",
    "functional_behavior": "Generate 3-phase, center-aligned, complementary PWM at 20 kHz with 1 µs dead-time on eGTM ATOM0 using channel pairs (U: CH0/1, V: CH2/4, W: CH6/8), use ATOM0.CH3 as phase-synchronous TMADC trigger via EGTM.ADC_OUT0; initialize duties to 25/50/75%; map PWM to P20.8–P20.13; route trigger to P33.0; use P03.9 as LED; start PWM and ADC trigger synchronously; move duty updates to a 500 ms STM0 main-loop while polling latest TMADC results.",
    "technical_approach": "Use unified IfxEgtm_Pwm to configure eGTM ATOM0 base + sync channels with DTM-managed 1 µs dead-time and center alignment; use IfxEgtm_Trigger_trigToAdc to route ATOM0.CH3 to EGTM.ADC_OUT0 for TMADC0 external triggering; configure TMADC0 CH0–CH4 via IfxAdc_Tmadc; configure pins via IfxEgtm_PinMap_setAtomTout and IfxPort; use IfxStm_get/IfxStm_getFrequency for 500 ms duty update cadence; initialize LED on P03.9 via IfxPort."
  },
