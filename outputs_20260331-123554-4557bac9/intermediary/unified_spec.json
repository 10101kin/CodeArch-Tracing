  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Implement 3-phase PWM motor control",
      "functional_behavior": "Generate three complementary center-aligned PWM pairs with hardware dead-time and an additional edge-aligned PWM that triggers TMADC one-shot conversions; read five ADC results in an ISR and toggle a GPIO; periodically update PWM duties from main without CPU sync and with watchdog handling migrated.",
      "technical_approach": "Use the unified IfxEgtm_Pwm driver to configure EGTM0.ATOM0 channels for: (1) three complementary center-aligned PWM pairs with synchronous updates and hardware dead-time; (2) one edge-aligned PWM for ADC trigger. Route ATOM0.CH3 to TMADC0 AdcTriggerSignal_0 via IfxEgtm_Trigger_trigToAdc. Initialize TMADC using IfxAdc_Tmadc module and channel APIs with 100 ns sampling and wait-for-read; enable a result event to invoke tmadcResultIsr, which reads available results and toggles the GPIO. Periodically adjust duties in updateEgtmAtom3phInvDuty every 500 ms using STM wait utilities. Replace SCU watchdog usage with IfxWtu."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified high-level PWM driver supports ATOM center/edge alignment, synchronous multi-channel updates, and dead-time management via integrated DTM path; it matches the migration target and is available in the template.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm",
        "IfxGtm_Pwm"
      ]
    },
    "driver_usage": {
      "initialization_apis": [
        "IfxEgtm_Pwm_initConfig",
