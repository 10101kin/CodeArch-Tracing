              "pin": "P20.8"
            },
            "low_side": {
              "channel": "CH0N",
              "pin": "P20.9"
            },
            "initial_duty_percent": 25.0
          },
          {
            "pair": "V",
            "high_side": {
              "channel": "CH1",
              "pin": "P20.10"
            },
            "low_side": {
