            },
            "initial_duty_percent": 50.0
          },
          {
            "pair": "W",
            "high_side": {
              "channel": "CH2",
              "pin": "P20.12"
            },
            "low_side": {
              "channel": "CH2N",
              "pin": "P20.13"
            },
            "initial_duty_percent": 75.0
          }
        ],
        "alignment": "center",
        "dead_time_rising_us": 1.0,
        "dead_time_falling_us": 1.0,
        "frequency_hz": 20000.0,
        "cmu_clock_id": 0
      },
      "adc_trigger": {
        "generator": {
          "cluster": 0,
          "module": "ATOM0",
          "channel": "CH3",
