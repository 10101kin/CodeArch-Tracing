    "peripheral_requirement": {
      "type": "PWM",
      "driver_available": true,
      "driver_name": "IfxEgtm_Pwm",
      "purpose": "eGTM Cluster 0 ATOM0 CH0–CH2 generate three complementary center-aligned PWM pairs with 1 us hardware dead-time at 20 kHz; ATOM0 CH3 edge-aligned 20 kHz, 50% duty falling-edge trigger for TMADC0.",
