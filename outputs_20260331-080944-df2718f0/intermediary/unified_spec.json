  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Implement 3-phase PWM motor control",
      "functional_behavior": "Generate a 3-phase complementary, center-aligned PWM at 20 kHz with 1 µs dead-time per edge, initial duties U/V/W = 25%/50%/75%, apply 10% step updates every 500 ms, start and update synchronously, and handle a period-event ISR toggling the board LED.",
      "technical_approach": "Use the unified PWM driver to configure EGTM ATOM0 Cluster 0 for a 3-phase complementary pair setup with center-aligned mode and DTM-based dead-time via the driver config; perform a single synced start and use synced duty updates; route the period-event to an ISR named EgtmAtomIsr (LED toggle) while enabling EGTM clocks and setting the LED GPIO as push-pull."
    },
