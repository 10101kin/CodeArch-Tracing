        "module": "EGTM ATOM0 Cluster 0",
        "topology": "3-phase complementary",
        "alignment": "center",
        "sync_start": true,
        "sync_update": true,
        "dead_time_us": {
          "rising": 1,
          "falling": 1
        },
        "channels": [
          {
            "phase": "U",
            "high_side": {
              "pin": "P20.8",
              "tout": "TOUT64"
            },
            "low_side": {
