              "tout": "TOUT67"
            }
          },
          {
            "phase": "W",
            "high_side": {
              "pin": "P20.12",
              "tout": "TOUT68"
            },
            "low_side": {
              "pin": "P20.13",
              "tout": "TOUT69"
            }
          }
        ],
        "gpio_output_mode": "pushPull",
        "pad_driver": "IfxPort_PadDriver_cmosAutomotiveSpeed1"
      },
