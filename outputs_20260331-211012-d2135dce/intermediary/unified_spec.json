      "driver_available": true,
      "driver_name": "IfxEgtm_Pwm",
      "purpose": "Generate 3-phase complementary, center-aligned PWM at 20 kHz with 1 µs rising/falling dead-time using eGTM ATOM0 Cluster 0 (TOUT64–69), synchronous start/update, and a period-event ISR to toggle LED P03.9.",
      "driver_locked": true,
      "driver_selection_source": "engine_scored"
    },
    "signal_requirements": {
