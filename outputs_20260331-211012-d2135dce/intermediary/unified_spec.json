  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate 3-phase PWM motor control to the TC4D7 target using eGTM ATOM with unified PWM APIs.",
      "functional_behavior": "Produce six complementary, center-aligned 20 kHz PWM outputs on ATOM0 Cluster 0 with 1 µs dead-time, initialize U/V/W duties to 25/50/75%, step duties by 10% each update, start and update synchronously, and run a period-event ISR on channel 0 to toggle LED P03.9. Ensure eGTM enable and CMU clock setup, push-pull outputs, and maintain the reference main loop timing.",
      "technical_approach": "Use the unified high-level PWM driver to configure one base plus five synchronous channels for ATOM0 Cluster 0, map TOUT64–69 via the driver's pin/pad fields, enable CMU clocks and the eGTM module, set center-aligned mode with complementary outputs and 1 µs dead-time in the config, and register a period-event interrupt on channel 0 via the driver’s interrupt configuration. Runtime duty updates use the unified bulk immediate API; LED pin uses IfxPort for push-pull and toggling."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified PWM provides center-aligned, complementary outputs with integrated DTM support, synchronized start/update, and a single configuration path for multi-channel ATOM setups. It matches the reference pattern while targeting eGTM and is available in the template.",
