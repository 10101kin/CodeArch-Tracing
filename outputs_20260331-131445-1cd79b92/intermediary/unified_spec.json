  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate the TC387 TOM/EVADC 3‑phase inverter app to TC4D7 and reproduce 3‑phase PWM with ADC-triggered sampling on the KIT_A3G_TC4D7_LITE.",
      "functional_behavior": "Generate EGTM CLS0 ATOM0 CH0–CH2 center‑aligned 20 kHz PWM with 1 µs hardware dead‑time and initial duties U=25%, V=50%, W=75%. Use ATOM0 CH3 as a 50% edge‑aligned trigger routed to TMADC0 via the EGTM trigger fabric. Sample 5 one‑shot TMADC0 SAR0 channels at 100 ns with wait‑for‑read, handle results in resultISR (priority 25, provider cpu0) and toggle LED on P03.9. Update phase duties every 500 ms.",
      "technical_approach": "Use EGTM ATOM mid-level timer to own the CH3 timebase/trigger path as required, combined with the unified EGTM PWM driver to configure CH0–CH2 center‑aligned complementary outputs with DTM for 1 µs dead‑time. Enable EGTM CMU CLK0 and route TOUT pins via EGTM PinMap. Connect ATOM0 CH3 to TMADC using IfxEgtm_Trigger_trigToAdc. Configure TMADC0 (module + 5 one‑shot channels) and install resultISR on cpu0; toggle P03.9 on result."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Atom_Timer",
      "selection_rationale": "Header selection mandates IfxEgtm_Atom_Timer. We use it to control ATOM0 CH3 timing and trigger generation deterministically for TMADC. For the 3‑phase outputs and dead‑time management, we pair it with the unified EGTM PWM driver, which is present in the template and provides immediate duty updates matching the legacy behavior.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Pwm",
        "IfxEgtm_Atom_Pwm"
      ]
    },
