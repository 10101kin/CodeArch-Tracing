  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Implement 3-phase PWM motor control",
      "functional_behavior": "Generate six synchronized TOM1 complementary PWM outputs (U/V/W HS+LS) in center-aligned mode with software deadtime and synchronous start/update; expose percent-based duty control with wrap/step behavior; run a periodic GTM ATOM ISR to toggle an LED; guard-enable GTM clocks.",
      "technical_approach": "Use the unified high-level GTM PWM driver to create six PWM channels on TOM1 Cluster_1 and a shared TOM timer for update gating. Compute HS/LS complementary duties and software deadtime in updateGtmTom3phInvDuty(), stage new duties with IfxGtm_Pwm_updateChannelsDuty(), then atomically commit via IfxGtm_Tom_Timer_disableUpdate() and IfxGtm_Tom_Timer_applyUpdate(). Use GTM guard APIs to enable module/clocks only if needed. Provide an empty IfxGtm_periodEventFunction callback and configure a GTM ATOM periodic ISR that toggles P13.0."
    },
    "driver_selection": {
      "recommended_driver": "IfxGtm_Pwm",
      "selection_rationale": "Unified PWM provides synchronized multi-channel updates, center-aligned operation, and simple API for duty updates while allowing explicit TOM timer-based update gating required by the user. It cleanly replaces the legacy PwmHl and is available in the template.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxGtm_Tom_PwmHl",
        "IfxGtm_Tom_Dtm_PwmHl",
        "IfxGtm_Tom_Pwm"
      ]
    },
