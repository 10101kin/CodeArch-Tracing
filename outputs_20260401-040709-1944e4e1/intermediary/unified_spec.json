  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate the existing 3‑phase motor PWM with synchronous ADC sampling from TC387 (TOM+EVADC) to TC4D7 (EGTM ATOM + TMADC) on KIT_A3G_TC4D7_LITE.",
      "functional_behavior": "Generate center‑aligned complementary 3‑phase PWM at 20 kHz with 1 µs dead-time on EGTM ATOM0 CH0–CH2 with initial duties U=25%, V=50%, W=75%. Use ATOM0 CH3 as a 50% edge‑aligned trigger routed to TMADC AdcTriggerSignal_0 on falling edge. Configure TMADC Module 0 CH0–CH4 for one‑shot on SAR0 with 100 ns sampling and wait-for-read; start conversions and service results in resultISR() that toggles P03.9. Update PWM duties in main every 500 ms using STM wait APIs. Replace SCU watchdog usage with WTU.",
      "technical_approach": "Use the unified EGTM PWM driver to configure ATOM0 with one base + synchronous channels for the 3 complementary phases and a separate channel for the ADC trigger. Dead-time and center alignment are set via IfxEgtm_Pwm configuration; channel updates are applied atomically. Route the trigger to TMADC with IfxEgtm_Trigger_trigToAdc(). Initialize TMADC via IfxAdc_Tmadc_initModuleConfig/initModule and per‑channel IfxAdc_Tmadc_initChannelConfig/initChannel, enable channel events, then start with IfxAdc_Tmadc_runModule(). Install resultISR() using the template’s interrupt infrastructure; inside ISR read five TMADC results and toggle P03.9 using IfxPort_togglePin. Periodically call updateEgtmAtomDuty() to refresh all three duties using IfxEgtm_Pwm_updateChannelsDutyImmediate, paced by STM wait APIs."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified high-level PWM supports ATOM center/edge alignment, complementary outputs with dead-time, synchronous multi-channel updates, and integrates well with EGTM CMU and trigger routing. It minimizes low-level handling while meeting the 3‑phase inverter and ADC sync requirements.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm",
        "IfxGtm_Pwm"
      ]
    },
    "driver_usage": {
      "initialization_apis": [
        "IfxEgtm_Pwm_initConfig",
        "IfxEgtm_Pwm_init",
        "IfxEgtm_isEnabled",
        "IfxEgtm_enable",
