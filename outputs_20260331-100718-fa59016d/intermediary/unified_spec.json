  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate the TC387 TOM/EVADC 3-phase inverter to TC4D7 using eGTM ATOM + TMADC with identical behavior.",
      "functional_behavior": "Generate three complementary, center-aligned PWM pairs on ATOM0 CH0–CH2 at 20 kHz with 1 µs CDTM dead-time and initial duties U=25%, V=50%, W=75%; output an edge-aligned 50% trigger on ATOM0 CH3 routed to AdcTriggerSignal_0; run TMADC0 with five one-shot channels (CH0–CH4) triggered on falling edge; service an ISR on CPU0 to read all five results and toggle P03.9; update PWM duties every 500 ms.",
      "technical_approach": "Use the unified IfxEgtm_Pwm driver on EGTM Cluster 0 to configure ATOM0 channels for complementary center-aligned PWM with CDTM-managed dead-time and a separate edge-aligned trigger channel; route the trigger to the ADC via IfxEgtm_Trigger_trigToAdc; configure TMADC0 channels with IfxAdc_Tmadc for one-shot conversions and enable channel events to invoke resultISR; control GPIO with IfxPort; update phase duties at runtime via IfxEgtm_Pwm_updateChannelsDutyImmediate."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified PWM driver supports ATOM-based center/edge alignment, complementary outputs with CDTM dead-time, synced groups, and provides immediate duty update APIs required by updateEgtmAtomDuty while simplifying initialization for multi-channel setups. It aligns with the migration goal and the locked PWM driver choice.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxGtm_Pwm"
      ]
    },
    "driver_usage": {
      "initialization_apis": [
        "IfxEgtm_Pwm_initConfig",
