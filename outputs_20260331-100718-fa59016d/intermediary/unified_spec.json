    "peripheral_requirement": {
      "type": "PWM",
      "driver_available": true,
      "driver_name": "IfxEgtm_Pwm",
      "purpose": "3-phase inverter complementary center-aligned PWM on EGTM ATOM0 with ADC trigger; duties updated at runtime",
      "driver_locked": true,
      "driver_selection_source": "engine_scored"
    },
    "signal_requirements": {
      "pwm": {
        "egtm_cluster": 0,
        "atom": 0,
        "channels": {
          "pairs_center_aligned": [
            {
              "phase": "U",
              "channels": [
                0
              ],
              "pins": {
                "high": "P20.8",
                "low": "P20.9"
              },
              "initial_duty_percent": 25
            },
            {
              "phase": "V",
              "channels": [
                1
              ],
              "pins": {
                "high": "P20.10",
                "low": "P20.11"
              },
              "initial_duty_percent": 50
            },
            {
              "phase": "W",
              "channels": [
                2
              ],
              "pins": {
                "high": "P20.12",
                "low": "P20.13"
              },
              "initial_duty_percent": 75
            }
          ],
          "adc_trigger": {
            "channel": 3,
            "mode": "edge_aligned",
            "duty_percent": 50,
            "route": "AdcTriggerSignal_0 via IfxEgtm_Trigger_trigToAdc()",
            "monitor_pin": "P33.0"
          }
        },
        "frequency_hz": 20000,
        "clock_source": "CMU_CLK0",
        "dead_time": {
          "type": "CDTM",
          "rising_ns": 1000,
          "falling_ns": 1000
        }
      },
      "adc": {
        "type": "TMADC",
        "module": "TMADC0",
        "sar_core": 0,
        "channels": [
          {
            "id": 0,
            "mode": "one_shot",
            "trigger_edge": "falling",
            "trigger_mux": "TriggerMuxSel_36"
          },
          {
            "id": 1,
            "mode": "one_shot",
            "trigger_edge": "falling",
            "trigger_mux": "TriggerMuxSel_36"
          },
          {
            "id": 2,
            "mode": "one_shot",
            "trigger_edge": "falling",
            "trigger_mux": "TriggerMuxSel_36"
          },
          {
            "id": 3,
            "mode": "one_shot",
            "trigger_edge": "falling",
            "trigger_mux": "TriggerMuxSel_36"
          },
          {
            "id": 4,
            "mode": "one_shot",
            "trigger_edge": "falling",
            "trigger_mux": "TriggerMuxSel_36"
          }
        ],
        "sample_time_ns": 100,
        "wait_for_read": true,
        "trigger_source": "EGTM.ATOM0.CH3 via AdcTriggerSignal_0",
        "analog_inputs_assumption": {
          "mapping": "TMADC0.AN0..AN4 (default analog pad selection for channels CH0..CH4)",
