        }
      },
      "isr": {
        "name": "resultISR",
        "cpu": "CPU0",
        "priority": 25,
        "vmId": "IfxSrc_VmId_0",
        "behavior": "On each trigger, read all 5 TMADC0 results (CH0..CH4), clear flags/WFR, and toggle P03.9"
