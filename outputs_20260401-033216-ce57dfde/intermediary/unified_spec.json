    "peripheral_requirement": {
      "type": "PWM",
      "driver_available": true,
      "driver_name": "IfxGtm_Tom_PwmHl",
      "purpose": "3-phase complementary center-aligned PWM on TOM1 Cluster_1 at 20 kHz with 1 us rising/falling dead time, synchronous start and synchronous update",
      "driver_locked": true,
      "driver_selection_source": "user_explicit"
    },
    "signal_requirements": {
      "pwm": {
        "module": "GTM.TOM1",
        "cluster": 1,
        "frequency_hz": 20000,
        "center_aligned": true,
        "complementary": true,
        "sync_start": true,
        "sync_update": true,
        "deadtime_us": {
          "rising": 1.0,
          "falling": 1.0
        },
        "channel_plan": {
          "U": {
            "high": {
              "tom_channel": 8,
              "pin": "P02.0",
              "pinmap_symbol": "IfxGtm_Tom_Tout_1_8_P02_0_OUT"
            },
            "low": {
              "tom_channel": 9,
              "pin": "P02.7",
              "pinmap_symbol": "IfxGtm_Tom_Tout_1_9_P02_7_OUT"
            }
          },
          "V": {
            "high": {
              "tom_channel": 10,
              "pin": "P02.1",
              "pinmap_symbol": "IfxGtm_Tom_Tout_1_10_P02_1_OUT"
            },
            "low": {
              "tom_channel": 11,
              "pin": "P02.4",
              "pinmap_symbol": "IfxGtm_Tom_Tout_1_11_P02_4_OUT"
            }
          },
          "W": {
            "high": {
              "tom_channel": 12,
              "pin": "P02.2",
              "pinmap_symbol": "IfxGtm_Tom_Tout_1_12_P02_2_OUT"
            },
            "low": {
              "tom_channel": 13,
              "pin": "P02.5",
              "pinmap_symbol": "IfxGtm_Tom_Tout_1_13_P02_5_OUT"
            }
          }
        },
        "pinmap_headers": [
          "IfxGtm_PinMap_TC38x_LFBGA516.h"
        ],
        "notes": "TOM1 Cluster_1 channels 8..13 are used as complementary pairs (8/9, 10/11, 12/13). Pin mapping symbols follow the standard naming and must be verified against IfxGtm_PinMap_TC38x_LFBGA516.h on the KIT_A2G_TC387_5V_TFT. If any listed TOUT-to-pin combination is unavailable, choose the closest TOUT option on the same channels for the specified P02.x pins."
      },
      "gpio": {
        "led_toggle_pin": "P13.0",
        "direction": "outputPushPull",
        "default_level": "low"
      },
      "isr": {
        "gtm_atom_timer": {
          "module": "GTM.ATOM0",
          "channel": 0,
          "frequency_hz": 2,
          "cpu": 0,
          "priority": 20,
          "tos": "IfxSrc_Tos_cpu0",
          "handler_actions": [
            "Toggle P13.0",
            "Call IfxGtm_periodEventFunction()"
          ]
        }
      },
      "duty_interface": {
        "units": "percent_0_to_100",
        "initial": {
          "U": 25.0,
          "V": 50.0,
          "W": 75.0
        },
        "step": 10.0,
        "wrap_rule": "if (duty + step) >= 100 then duty = 0; then add step",
        "min_pulse_time_s": 1e-06
      }
    },
    "timing_requirements": {
      "gtm_cmu": {
        "clk_source": "CMU_CLK0",
        "clk_hz": 100000000,
        "period_ticks_nominal": 5000,
        "deadtime_ticks": 100,
        "notes": "At 100 MHz CMU_CLK0, 1 us dead time = 100 ticks. Period ticks of 5000 correspond to 20 kHz; center-aligned operation handled by driver."
      },
      "stm": {
        "update_interval_ms": 500,
        "api": "IfxStm_getTicksFromMilliseconds"
      }
    },
