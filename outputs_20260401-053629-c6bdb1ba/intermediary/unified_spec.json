  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate TC387 TOM+EVADC 3-phase inverter to TC4D7 using EGTM ATOM for PWM and TMADC for ADC on KIT_A3G_TC4D7_LITE.",
      "functional_behavior": "Generate three center-aligned complementary PWMs (ATOM0 CH0–CH2) at 20 kHz with 1 µs dead-time and initial duties U=25%, V=50%, W=75%; produce an edge-aligned 50% trigger on ATOM0 CH3 routed to TMADC via IfxEgtm_Trigger_trigToAdc(AdcTriggerSignal_0); run TMADC0 in one-shot on 5 channels with 100 ns sampling and falling-edge trigger; service results in resultISR() reading 5 channels and toggling P03.9; update PWM duties in main loop every 500 ms.",
      "technical_approach": "Use unified EGTM PWM driver for ATOM-based complementary outputs and dead-time; configure trigger routing with IfxEgtm_Trigger_trigToAdc; initialize and run TMADC using the available TMADC service-request configuration helpers in IfxAdc_*; install a periodic main-loop update calling the PWM immediate duty update API and use IfxPort for ISR pin toggle."
    },
    "driver_selection": {
      "recommended_driver": "IfxAdc_Tmadc_Servrequestconfig",
      "selection_rationale": "ADC/TMADC is locked by migration spec; the template exposes TMADC control via IfxAdc_* helpers for module enable/run, sampling/trigger conversions, and triggering channel sets, which satisfies one-shot, trigger-driven conversions and ISR servicing.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxAdc_Tmadc",
        "IfxEgtm_Pwm",
        "IfxEgtm_Atom_Pwm"
      ]
    },
