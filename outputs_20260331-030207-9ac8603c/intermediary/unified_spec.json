  "sw_detailed": {
    "module_name": "GTM_TOM_3_Phase_Inverter_PWM",
    "public_functions": [
      {
        "signature": "void updateGtmTom3phInvDuty(void)",
        "behavior_description": "Initialize three independent single-ended PWM channels on the GTM TOM module using the unified high-level PWM driver. Steps: 1) Declare local configuration structures (main PWM config and a per-channel config array sized for 3 channels). 2) Initialize the main config with driver defaults. 3) Fill the per-channel configurations directly: assign three output pins from the hardware-defined pin macros, set active-high polarity, push-pull output mode, and automotive pad driver. 4) Configure the main PWM parameters: center-aligned operation, requested PWM frequency (20 kHz), use the first functional clock for TOM channels, and enable synchronous start of the configured channels. 5) Prepare persistent module state: allocate and retain a driver handle, a channels array (persisting beyond function scope), and arrays for dutyCycles (size 3) to store U/V/W duty in percent. 6) Inside an enable guard, check whether the GTM is already enabled; if not, enable it, read the module frequency dynamically for reference, and enable functional clocks for the TOM domain (FXCLK) so PWM timing runs. 7) Call the high-level PWM init with the persistent channels array and the populated config; this binds the outputs and applies the initial per-channel settings. 8) Populate the state’s dutyCycles array with initial values [25, 50, 75] percent; these initial duties are applied by embedding them in the channel configuration prior to init so the outputs start with the requested duty distribution. No STM timing, scheduling, or delays are performed here.",
        "driver_calls": [
          "IfxGtm_isEnabled",
          "IfxGtm_enable",
          "IfxGtm_Cmu_getModuleFrequency",
          "IfxGtm_Cmu_enableClocks",
          "IfxGtm_Pwm_initConfig",
          "IfxGtm_Pwm_init"
        ],
        "from_reference": true,
        "call_context": "loop"
      },
      {
        "signature": "void updateGtmTom3phInvDuty(void)",
        "behavior_description": "Update the three PWM channel duties using a simple step-and-wrap algorithm. Maintain a persistent array of three duty percentages [U, V, W] in the module state. On each call: 1) For indices 0..2, add a fixed step of +10 to each duty value. 2) If any duty reaches or exceeds 100, wrap it to 0. 3) Pass the updated three-element duty array (in percent) directly to the unified multi-channel immediate update API to apply the new duty cycle atomically to all three outputs.",
        "driver_calls": [
          "IfxGtm_Pwm_updateChannelsDutyImmediate"
        ],
        "from_reference": true,
        "call_context": "loop"
      }
    ],
    "private_functions": [],
