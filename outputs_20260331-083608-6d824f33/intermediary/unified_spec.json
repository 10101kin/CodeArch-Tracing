  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Implement 3-phase PWM motor control",
      "functional_behavior": "Generate three complementary, center-aligned PWM phases at 20 kHz with 1 μs dead-time and initial duties U=25%, V=50%, W=75%, using eGTM ATOM with DTM, synchronized start/update, and a single period interrupt that toggles a low-active LED.",
      "technical_approach": "Use the unified high-level PWM driver to configure EGTM ATOM with DTM for complementary outputs and center-aligned mode, enable FXCLK-based timing and synchronized updates, and bind a period ISR that toggles the LED. Runtime duty updates use the driver's synchronized update API."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified PWM driver supports ATOM+DTM complementary outputs, center-aligned mode, syncStart/syncUpdate, dead-time, and period-interrupt handling through a single configuration and runtime API set, matching the requirement while minimizing low-level handling.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm"
      ]
    },
    "driver_usage": {
