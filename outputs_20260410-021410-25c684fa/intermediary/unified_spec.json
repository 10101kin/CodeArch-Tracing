  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Implement 3-phase PWM motor control",
      "functional_behavior": "Generate 3 complementary center-aligned PWM pairs on TOM1 TGC1 at 20 kHz with 1 µs rising/falling deadtime, start and update all six channels synchronously, provide percent-based duty updates with wrap rule, guard GTM enable/clock setup, expose initGtmTom3phInv() and updateGtmTom3phInvDuty(), install a 1 kHz ATOM0 CH0 ISR to toggle P13.0, and provide an empty IfxGtm_periodEventFunction.",
      "technical_approach": "Use the unified high-level PWM driver to configure TOM1 Cluster_1 (channels 8..13) in center-aligned complementary mode with hardware deadtime and TGC1 synchronous start/shadow update. Route the six TOUT signals to P02.* using the TC38x_516 pinmap entries resolved in hardware. Enable and clock GTM with a guard (check DISS and enable CMU TOM clock). Provide a stub IfxGtm_periodEventFunction. For the 1 kHz periodic ISR, use IfxGtm_Atom_Timer on ATOM0 CH0 and route to SRC_GTM_ATOM0_0 with priority 20; in the ISR toggle P13.0 via IfxPort. The application calls initGtmTom3phInv() once, then loops calling updateGtmTom3phInvDuty() and delaying via STM ticks."
    },
    "driver_selection": {
      "recommended_driver": "IfxGtm_Pwm",
      "selection_rationale": "It natively supports multi-channel TOM cluster PWM with center-aligned complementary mode, deadtime handling, and synchronous start/update via TGC, matching the inverter requirement while simplifying initialization compared to submodule-specific drivers.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxGtm_Tom_Dtm_PwmHl",
        "IfxGtm_Tom_PwmHl",
        "IfxGtm_Tom_Pwm",
        "IfxCcu6_PwmHl"
      ]
    },
