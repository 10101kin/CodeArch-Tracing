  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Implement 3-phase PWM motor control",
      "functional_behavior": "Generate 3 complementary PWM phases on TOM1 Cluster_1 (pairs 0/1, 2/3, 4/5) in center-aligned mode at 20 kHz with hardware dead-time, sync start and sync update enabled; expose initGtmTom3phInv() and updateGtmTom3phInvDuty() with a percent-based interface (U/V/W start at 25/50/75, step 10%, wrap to step when >=100); guard GTM enablement and reuse CMU clocking; fire a period ISR from TOM1 CH0 (priority 20) that toggles P13.0 every PWM period; provide empty IfxGtm_periodEventFunction; application updates duties every 500 ms.",
      "technical_approach": "Use the unified PWM driver to configure TOM1 Cluster_1 with 3 complementary channel pairs, center-aligned at 20 kHz, and hardware dead-time set in the driver config (0.5 µs rising and falling per migration numeric override). Enable sync start/update across CH0–CH5. Guard GTM enablement and only enable CMU clocks if needed. The driver’s interrupt configuration routes a TOM1 CH0 period event to an ISR that toggles P13.0 each period. The runtime duty update uses a percent array and IfxGtm_Pwm_updateChannelsDutyImmediate to apply synchronized updates with the specified step and wrap rule."
    },
    "driver_selection": {
      "recommended_driver": "IfxGtm_Pwm",
      "selection_rationale": "Unified PWM provides center-aligned mode, complementary pairing with hardware dead-time via DTM, synchronous start/update across multiple channels, and percent-based frequency/duty updates while abstracting TOM-specific details. It cleanly replaces the legacy TOM_PwmHl with simpler init and synchronized multi-channel control.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxGtm_Tom_PwmHl",
        "IfxGtm_Tom_Dtm_PwmHl",
        "IfxGtm_Atom_Dtm_PwmHl",
        "IfxCcu6_PwmHl"
      ]
    },
    "driver_usage": {
