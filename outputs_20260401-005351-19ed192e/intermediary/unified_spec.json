  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate 3-phase PWM motor control to new AURIX target",
      "functional_behavior": "Generate three complementary, center-aligned PWM pairs at 20 kHz with 1 µs dead-time on ATOM0 CH0–CH2 and an edge-aligned 20 kHz 50% duty ADC trigger on ATOM0 CH3; route the trigger to TMADC, sample 5 channels in one-shot mode, toggle P03.9 in the ADC ISR, and step phase duties by 1% every 500 ms.",
      "technical_approach": "Use the unified PWM driver to configure ATOM0 channels with complementary outputs and dead-time, then update all phase duties at runtime using the immediate multi-channel update API. Route ATOM0 CH3 to TMADC via the EGTM trigger API. Initialize and run TMADC with per-channel configuration and service the results in an ISR. Configure the GPIO toggle pin with the Port driver."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified PWM driver natively supports ATOM-based complementary, center-aligned PWM with dead-time and provides a single API surface for synced multi-channel updates, matching the migration goal while simplifying initialization and runtime duty control.",
