  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Implement eGTM ATOM-based multi-channel PWM with ADC trigger and TMADC acquisition on KIT_A3G_TC4D7_LITE, replacing TC3xx TOM+EVADC.",
      "functional_behavior": "Generate ATOM0 CH0–CH2 center-aligned complementary PWM at 20 kHz with 1 µs dead-time and initial duties U/V/W = 25/50/75%. Use ATOM0 CH3 edge-aligned 50% as ADC trigger via AdcTriggerSignal_0 (TriggerMuxSel_36 falling). Configure TMADC0 CH0–CH4 one-shot on SAR0 with 100 ns sampling and WFR. Provide resultISR() to read all 5 channels. Update duties every 500 ms and toggle LED.",
      "technical_approach": "Use ATOM Timer to provide the timing/trigger framework (incl. CH3 trigger configuration) and unified eGTM PWM driver to configure ATOM0 channels 0–2 as complementary center-aligned with hardware DTM and to update duties immediately. Route ATOM0.CH3 to TMADC using the eGTM Trigger API. Initialize and run TMADC module and channels with TMADC APIs, install ISR, and use Port/STM for LED and timing."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Atom_Timer",
      "selection_rationale": "Selected to explicitly control ATOM timing and set up CH3 as an edge-aligned trigger source for TMADC while collaborating with the unified eGTM PWM driver for multi-channel complementary PWM with DTM. This aligns with the migration goal (ATOM-based PWM, TMADC trigger) and the mandatory header selection.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Pwm",
        "IfxEgtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm"
      ]
    },
