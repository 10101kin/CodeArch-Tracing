  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate the existing 3-phase inverter control to TC4D7 using EGTM ATOM for PWM and TMADC for ADC with the same behaviors as the TC3xx app.",
      "functional_behavior": "Generate three complementary, center-aligned PWM pairs at 20 kHz with 1 µs dead-time and correct HS/LS polarities; provide an edge-aligned 50% ADC trigger from a dedicated ATOM channel; configure TMADC channels for one-shot conversions with wait-for-read; service ADC results via an ISR; toggle a status LED and periodically update PWM duties; replace legacy watchdog usage.",
      "technical_approach": "Use the unified high-level EGTM PWM driver to create a synchronized 3-phase complementary setup with hardware DTM and center alignment. Route an ATOM channel trigger to TMADC via IfxEgtm_Trigger_trigToAdc. Initialize and run TMADC using IfxAdc_Tmadc module/group/channel APIs (one-shot, 100 ns sampling, wait-for-read) and configure the result service request as specified. Replace watchdog calls with IfxWtu_* APIs. Keep main loop duty updates and LED toggling."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Mandatory header selection requires the unified EGTM PWM driver. It supports synchronized multi-channel, center-aligned complementary outputs with DTM, and abstracts ATOM/DTM/pin routing/ISR into a single configuration, minimizing migration effort while meeting the inverter’s timing and polarity requirements.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxGtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm"
      ]
    },
