  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate the existing TC3xx 3‑phase motor PWM with synchronous ADC sampling to TC4D7, keeping the same functional behavior and callable API names.",
      "functional_behavior": "Generate three complementary, center‑aligned PWM phase pairs at 20 kHz with 1 µs dead‑time and initial duties U/V/W = 25%/50%/75% on EGTM Cluster 0 ATOM0 CH0–CH2; provide an edge‑aligned 50% channel on ATOM0 CH3 to trigger TMADC; trigger TMADC0 CH0–CH4 one‑shot on falling edge; service results in resultISR() (prio 25) and toggle LED; update duties every 500 ms via updateEgtmAtomDuty().",
      "technical_approach": "Use the unified PWM driver to configure EGTM C0 ATOM0 with one base channel and synchronous channels for a 3‑phase complementary, center‑aligned PWM, with DTM dead‑time provided via the unified config. Map ATOM0 CH3 as an edge‑aligned 50% trigger source and connect it to TMADC using IfxEgtm_Trigger_trigToAdc(). Initialize TMADC0 and CH0–CH4 using IfxAdc_Tmadc_initModuleConfig/initModule and IfxAdc_Tmadc_initChannelConfig/initChannel, set 100 ns sampling and one‑shot with wait‑for‑read, run the module, and enable channel events. Install resultISR() (prio 25, TOS cpu0) to read all five results, then clear result flags and toggle P03.9 using IfxPort APIs. Replace legacy watchdog calls with IfxWtu. The main loop delays via IfxStm and calls updateEgtmAtomDuty(), which updates all phase duties atomically using IfxEgtm_Pwm_updateChannelsDutyImmediate()."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "Unified EGTM PWM cleanly supports center/edge alignment, complementary outputs, dead‑time (via DTM attachment in config), synchronous multi‑channel updates, and duty/phase changes. It also abstracts pin routing and interrupt setup, matching the migration goal while minimizing low‑level handling.",
      "available_in_template": true,
      "complexity_level": "advanced",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxGtm_Pwm",
        "IfxEgtm_Tom_Pwm"
      ]
    },
