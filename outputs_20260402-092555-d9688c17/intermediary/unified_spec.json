  "sw_architecture": {
    "user_intent_preservation": {
      "original_goal": "Migrate 3-phase PWM motor control from TC387 (GTM TOM + EVADC) to TC4D7 (eGTM ATOM + ADC TMADC) on KIT_A3G_TC4D7_LITE.",
      "functional_behavior": "Generate 3-phase center-aligned complementary PWM at 20 kHz with 1 µs dead-time on EGTM Cluster 0 ATOM0 CH0–CH2, an edge-aligned 50% trigger on ATOM0 CH3 routed to TMADC0, initialize TMADC0 one-shot channels (CH0–CH4) and read results in an ISR that toggles a GPIO; provide updateEgtmAtomDuty() to update all 3 PWM duties immediately; ensure HS active-high, LS active-low; add vmId=IfxSrc_VmId_0 to any PWM ISR config if used.",
      "technical_approach": "Use the unified high-level PWM driver to configure ATOM0 PWM (center/edge alignment, complementary outputs, dead-time, polarity, CMU clock) and provide immediate duty updates. Route ATOM0 CH3 trigger to TMADC via the eGTM trigger API. Initialize TMADC using the TMADC high-level driver and read channel results in an ISR which toggles a GPIO. Replace SCU WDT usage with WTU in main. Duty updates are paced in main via STM waitTime."
    },
    "driver_selection": {
      "recommended_driver": "IfxEgtm_Pwm",
      "selection_rationale": "The unified eGTM PWM driver directly fulfills the user's requirement to implement PWM with IfxEgtm_Pwm on EGTM Cluster 0 ATOM0, including complementary pairs, center/edge alignment, dead-time, polarity, and immediate duty updates. ADC is handled by a companion driver (IfxAdc_Tmadc) and the trigger by IfxEgtm_Trigger. Selecting a non-PWM driver for this PWM-centric requirement would not preserve user intent.",
      "available_in_template": true,
      "complexity_level": "moderate",
      "alternatives_considered": [
        "IfxEgtm_Atom_Pwm",
        "IfxEgtm_Tom_Pwm",
        "IfxAdc_Tmadc"
      ]
    },
